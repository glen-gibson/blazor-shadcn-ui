@namespace NeoUI.Blazor
@typeparam TItem
@attribute [CascadingTypeParameter(nameof(TItem))]
@using NeoUI.Blazor.Services.Grid
@using NeoUI.Blazor.Primitives
@implements IAsyncDisposable

<CascadingValue Value="this" IsFixed="true">
    <div class="@ContainerCssClass" style="@GetGridContainerStyle()">
        @if (!_initialized && !_columnsRegistered)
        {
            @* Initializing state - shown only until columns register on the first render.
               _isInitializing is intentionally excluded: keeping the grid container div in the
               DOM during async AG Grid setup prevents a race condition where a sibling grid's
               TotalServerRowCountChanged triggers a parent StateHasChanged, Blazor re-renders
               this grid with the spinner, removes the container div, and AG Grid initializes
               into a now-detached element — leaving a permanently empty grid. *@
            @if (InitializingTemplate != null)
            {
                @InitializingTemplate
            }
            else
            {
                <div class="flex items-center justify-center h-full p-8">
                    <Spinner Size="SpinnerSize.Small" />
                </div>
            }
        }
        else if (IsLoading)
        {
            @* Loading state - shown when fetching/refreshing data *@
            @if (LoadingTemplate != null)
            {
                @LoadingTemplate
            }
            else
            {
                <div class="flex items-center justify-center h-full p-8">
                    <Spinner Size="SpinnerSize.Medium" />
                </div>
            }
        }
        else if (_columns.Count == 0 && _columnsRegistered)
        {
            <div class="text-sm text-muted-foreground p-4">
                No columns defined. Add DataGridColumn components inside the Columns parameter.
            </div>
        }
        else
        {
            @* AG DataGrid requires explicit height and theme class *@
            <div @ref="_gridContainer" class="@GetGridCssClass()" style="@GetGridStyle()"></div>

            @* BlazorServerSide custom pagination bar — replaces AG Grid's built-in panel which
           can only count rowData.length (one page) and would always show "of pageSize". *@
            @if (RowModelType == DataGridRowModelType.BlazorServerSide && PagingMode != DataGridPagingMode.None)
            {
                @* Kept in step with DataTable's and DataView's pagination rows. See DataTable.razor. *@
                <Pagination State="_blazorPaginationState"
                            PageSizes="@(new int[]{ 10, 20, 25, 50, 100 })"
                            OnPageChanged="OnBlazorPageChangedAsync"
                            OnPageSizeChanged="OnBlazorPageSizeChangedAsync"
                            Class="flex flex-wrap items-center justify-between gap-y-2 border-t px-2 py-4">
                    <PaginationInfo />
                    <PaginationContent Class="flex items-center gap-2 sm:gap-4 lg:gap-8">
                        <PaginationPageSizeSelector />
                        <div class="flex items-center gap-2">
                            <PaginationPageDisplay Class="hidden lg:flex" />
                            <div class="flex items-center gap-1">
                                <PaginationItem Class="hidden sm:flex"><PaginationFirst /></PaginationItem>
                                <PaginationItem><PaginationPrevious ShowText="false" /></PaginationItem>
                                <PaginationItem><PaginationNext ShowText="false" /></PaginationItem>
                                <PaginationItem Class="hidden sm:flex"><PaginationLast /></PaginationItem>
                            </div>
                        </div>
                    </PaginationContent>
                </Pagination>
            }
        }
    </div>

    @* Capture column definitions *@
    @Columns
</CascadingValue>
